generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model CreditCard {
  id              String   @id
  name            String
  shortName       String   @map("short_name")
  bank            String
  network         String
  tier            String
  annualFee       Int      @map("annual_fee")
  minIncome       Int      @map("min_income")
  imageUrl        String?  @map("image_url")
  bestFor         String?  @map("best_for")
  notIdealFor     String?  @map("not_ideal_for")
  loungeAccess    Boolean  @default(false) @map("lounge_access")
  travelInsurance Boolean  @default(false) @map("travel_insurance")
  airportTransfer Boolean  @default(false) @map("airport_transfer")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  earningRates     EarningRate[]
  transferPartners TransferPartner[]
  pros             CardPro[]
  cons             CardCon[]
  applications     CardApplication[]

  @@index([bank], map: "idx_cards_bank")
  @@index([bank, name], map: "idx_cards_bank_name")
  @@index([annualFee, name], map: "idx_cards_annual_fee_name")
  @@index([tier], map: "idx_cards_tier")
  @@index([updatedAt(sort: Desc)], map: "idx_cards_updated")
  @@map("credit_cards")
}

model CardApplication {
  id        String   @id @default(uuid()) @db.Uuid
  cardId    String   @map("card_id")
  source    String   @default("card_detail")
  createdAt DateTime @default(now()) @map("created_at")

  card CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId], map: "idx_card_applications_card")
  @@index([createdAt(sort: Desc)], map: "idx_card_applications_created")
  @@map("card_applications")
}

model EarningRate {
  id              String @id @default(uuid()) @db.Uuid
  cardId          String @map("card_id")
  transactionType String @map("transaction_type")
  spendPerPoint   Int    @map("spend_per_point")
  pointsEarned    Float  @map("points_earned")

  card CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId], map: "idx_earning_rates_card")
  @@index([transactionType], map: "idx_earning_rates_type")
  @@map("earning_rates")
}

model TransferPartner {
  id             String @id @default(uuid()) @db.Uuid
  cardId         String @map("card_id")
  program        String
  pointsRequired Int    @map("points_required")
  milesReceived  Int    @map("miles_received")

  card CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId], map: "idx_transfer_partners_card")
  @@index([program], map: "idx_transfer_partners_program")
  @@map("transfer_partners")
}

model CardPro {
  id     String @id @default(uuid()) @db.Uuid
  cardId String @map("card_id")
  text   String

  card CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId], map: "idx_card_pros_card")
  @@map("card_pros")
}

model CardCon {
  id     String @id @default(uuid()) @db.Uuid
  cardId String @map("card_id")
  text   String

  card CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId], map: "idx_card_cons_card")
  @@map("card_cons")
}

model Article {
  id          String    @id
  title       String
  excerpt     String?
  content     String?
  category    String
  subCategory String?   @map("sub_category")
  author      String?
  imageUrl    String?   @map("image_url")
  premium     Boolean   @default(false)
  dealTag     String?   @map("deal_tag")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([category], map: "idx_articles_category")
  @@index([publishedAt(sort: Desc)], map: "idx_articles_published")
  @@index([premium], map: "idx_articles_premium")
  @@index([category, publishedAt(sort: Desc)], map: "idx_articles_category_published")
  @@index([category, subCategory, publishedAt(sort: Desc)], map: "idx_articles_category_subcategory_published")
  @@index([updatedAt(sort: Desc)], map: "idx_articles_updated")
  @@map("articles")
}

model MembershipTier {
  id            String  @id
  name          String
  priceIdr      Int     @map("price_idr")
  period        String
  features      Json
  isHighlighted Boolean @default(false) @map("is_highlighted")
  sortOrder     Int?    @map("sort_order")

  paymentOrders PaymentOrder[]

  @@index([sortOrder, priceIdr], map: "idx_membership_tiers_sort_price")
  @@map("membership_tiers")
}

model ConsultingPackage {
  id          String  @id
  name        String
  description String?
  priceIdr    Int?    @map("price_idr")
  priceLabel  String? @map("price_label")
  outputs     Json
  icon        String?

  inquiries ConsultingInquiry[]

  @@index([priceIdr, name], map: "idx_consulting_packages_price_name")
  @@map("consulting_packages")
}

model ConsultingInquiry {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String
  phone        String?
  packageId    String?  @map("package_id")
  currentCards String?  @map("current_cards")
  needs        String?
  status       String   @default("new")
  createdAt    DateTime @default(now()) @map("created_at")

  package ConsultingPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([status], map: "idx_inquiries_status")
  @@index([status, createdAt(sort: Desc)], map: "idx_inquiries_status_created")
  @@index([packageId], map: "idx_inquiries_package")
  @@index([createdAt(sort: Desc)], map: "idx_inquiries_created")
  @@map("consulting_inquiries")
}

model NewsletterSubscriber {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @unique(map: "idx_newsletter_email")
  subscribedAt   DateTime  @default(now()) @map("subscribed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")

  @@index([subscribedAt(sort: Desc)], map: "idx_newsletter_subscribed")
  @@map("newsletter_subscribers")
}

model User {
  id             String   @id
  name           String
  email          String   @unique(map: "idx_users_email")
  emailVerified  Boolean  @default(false) @map("email_verified")
  image          String?
  membershipTier String   @default("free") @map("membership_tier")
  membershipExpiresAt DateTime? @map("membership_expires_at")
  role           String   @default("user")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]
  paymentOrders PaymentOrder[]

  @@index([membershipTier], map: "idx_users_membership_tier")
  @@index([role], map: "idx_users_role")
  @@map("users")
}

model PaymentOrder {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @map("user_id")
  tierId               String    @map("tier_id")
  orderId              String    @unique(map: "idx_payment_orders_order_id") @map("order_id")
  gatewayTransactionId String?   @map("gateway_transaction_id")
  platformOrderId      String?   @unique(map: "idx_payment_orders_platform_order_id") @map("platform_order_id")
  amount               Int
  currency             String    @default("IDR")
  status               String    @default("pending")
  paymentType          String    @default("bank_transfer") @map("payment_type")
  paymentMethod        String?   @map("payment_method")
  customerEmail        String    @map("customer_email")
  customerName         String    @map("customer_name")
  gatewayPayload       Json      @map("gateway_payload")
  paidAt               DateTime? @map("paid_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier          MembershipTier        @relation(fields: [tierId], references: [id], onDelete: Restrict)
  webhookEvents PaymentWebhookEvent[]

  @@index([userId, status], map: "idx_payment_orders_user_status")
  @@index([tierId], map: "idx_payment_orders_tier")
  @@index([status, createdAt(sort: Desc)], map: "idx_payment_orders_status_created")
  @@map("payment_orders")
}

model PaymentWebhookEvent {
  id             String   @id @db.Uuid
  paymentOrderId String?  @map("payment_order_id") @db.Uuid
  event          String
  status         String
  signatureValid Boolean  @map("signature_valid")
  payload        Json
  receivedAt     DateTime @default(now()) @map("received_at")

  paymentOrder PaymentOrder? @relation(fields: [paymentOrderId], references: [id], onDelete: SetNull)

  @@index([paymentOrderId], map: "idx_payment_webhook_events_order")
  @@index([receivedAt(sort: Desc)], map: "idx_payment_webhook_events_received")
  @@map("payment_webhook_events")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String   @unique(map: "idx_sessions_token")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_sessions_user")
  @@index([expiresAt], map: "idx_sessions_expires")
  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_accounts_user")
  @@index([providerId, accountId], map: "idx_accounts_provider_account")
  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier], map: "idx_verifications_identifier")
  @@index([expiresAt], map: "idx_verifications_expires")
  @@map("verifications")
}
