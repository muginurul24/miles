# Database URL for PostgreSQL
DATABASE_URL="postgresql://username:password@localhost:5432/mydb"

# Redis cache, session storage, and rate limiting
REDIS_URL=redis://localhost:6379

# Better Auth configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# Public app URL
SERVER_URL=http://localhost:3000
VITE_APP_TITLE=JustMiles

# PayGate store integration
PAYGATE_API_BASE_URL=https://paygate.digixsolution.net
PAYGATE_STORE_API_TOKEN=
PAYGATE_WEBHOOK_SECRET=
PAYGATE_WEBHOOK_TOLERANCE_SECONDS=300
PAYGATE_CALLBACK_URL=http://localhost:3000/api/payments/webhook
PAYGATE_DEFAULT_PAYMENT_METHOD=qris_gopay
